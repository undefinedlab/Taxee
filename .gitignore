node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ── TypeScript build output ────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Turborepo ─────────────────────────────────────────────────────────────────
.turbo/

# ── Next.js (frontend) ────────────────────────────────────────────────────────
frontend/.next/
frontend/out/
