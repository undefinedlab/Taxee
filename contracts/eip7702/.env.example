# Private key for deployment (with 0x prefix)
# This account needs Base Sepolia ETH
# Get from: https://www.coinbase.com/faucets/base-sepolia-faucet
PRIVATE_KEY=0x

# Base Sepolia RPC (optional, defaults to public endpoint)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Base Mainnet RPC (optional)
BASE_RPC=https://mainnet.base.org

# BaseScan API Key for contract verification
# Get from: https://basescan.org/apis
BASESCAN_API_KEY=

# Railway / API — authorize this key on TaxeeManager (deploy script uses deployer)
# EIP7702_EXECUTOR_PRIVATE_KEY=0x
# TAXEE_MANAGER_ADDRESS=0xEE8DAE2D3f142052bDb704Ba0D94e04eC1680193
# DELEGATION_REGISTRY_ADDRESS=0x403Fe0408976b518b2952BdF590135Ec6ba12ebc
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
