# Private key for deployment (with 0x prefix)
# This account needs Base Sepolia ETH (get from https://www.coinbase.com/faucets/base-sepolia-faucet)
PRIVATE_KEY=0x

# Base Sepolia RPC URL (optional, defaults to public endpoint)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Base Mainnet RPC URL (optional)
BASE_RPC=https://mainnet.base.org

# BaseScan API Key for contract verification
# Get from https://basescan.org/apis
BASESCAN_API_KEY=

# Circle Wallets API Key (for backend integration)
CIRCLE_API_KEY=

# Frontend Environment Variables
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
NEXT_PUBLIC_DELEGATION_REGISTRY_SEPOLIA=
NEXT_PUBLIC_TAXEE_MANAGER_SEPOLIA=
