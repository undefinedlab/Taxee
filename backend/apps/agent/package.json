{
  "name": "@taxee/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./heartbeat": {
      "import": "./dist/heartbeat.js",
      "types": "./dist/heartbeat.d.ts"
    }
  },
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx --watch src/index.ts",
    "dev:trigger": "node --env-file=../../.env.local --import tsx src/trigger.ts",
    "trigger": "node dist/trigger.js",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@taxee/shared": "workspace:*",
    "@taxee/tax-engine": "workspace:*",
    "@taxee/aggregator": "workspace:*",
    "@taxee/llm": "workspace:*",
    "@taxee/execution": "workspace:*",
    "@taxee/compliance": "workspace:*",
    "@taxee/notifications": "workspace:*",
    "@taxee/db": "workspace:*",
    "drizzle-orm": "^0.30.7",
    "postgres": "^3.4.3",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsx": "^4.7.3",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11"
  }
}
