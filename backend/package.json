{
  "name": "taxee-backend",
  "private": true,
  "version": "0.1.0",
  "main": "apps/api/dist/index.js",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build --filter=@taxee/api...",
    "build:all": "turbo run build",
    "start": "node apps/api/dist/index.js",
    "start:api": "pnpm --filter @taxee/api start",
    "start:agent": "pnpm --filter @taxee/agent start",
    "start:telegram-bot": "pnpm --filter @taxee/telegram-bot start",
    "start:mcp-server": "pnpm --filter @taxee/mcp-server start",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "db:migrate": "pnpm --filter @taxee/api db:migrate",
    "db:seed": "pnpm --filter @taxee/api db:seed",
    "db:seed:demo": "pnpm --filter @taxee/api db:seed:demo",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "smoke:prod": "node scripts/smoke-production.mjs",
    "check:telegram": "node scripts/check-telegram-bot.mjs"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.5",
    "prettier": "^3.2.5",
    "@types/node": "^20.12.7"
  }
}
