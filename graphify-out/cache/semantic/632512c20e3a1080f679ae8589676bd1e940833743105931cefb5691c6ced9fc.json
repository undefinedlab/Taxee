{"nodes": [{"id": "taxee_system", "label": "Taxee System", "file_type": "document", "source_file": "architecture.md", "source_location": null, "rationale": "Core system for DeFi portfolio agent that optimizes after-tax return, not gross performance. Core split: deterministic code does math; the LLM does judgment on structured inputs.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "design_principle_tax_first_class", "label": "Tax First-Class Input Principle", "file_type": "document", "source_file": "architecture.md", "source_location": "section 1", "rationale": "Every rebalance, rotation, and harvest decision runs through a tax-cost model before execution. Tax is treated as a primary optimization target rather than an afterthought.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "design_principle_lots_unit_truth", "label": "Lots as Unit of Truth Principle", "file_type": "document", "source_file": "architecture.md", "source_location": "section 1", "rationale": "Positions decompose into identifiable tax lots (acquisition date, cost basis, quantity, chain). Enables precise tax calculations and lot-specific strategies like HIFO.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "design_principle_code_llm_split", "label": "Code Computes LLM Judges Principle", "file_type": "document", "source_file": "architecture.md", "source_location": "section 1", "rationale": "Thresholds, drift, lot selection, and gain/loss math are deterministic; ambiguous trade-offs go to the LLM. The LLM is not doing math - it receives structured inputs and applies judgment.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "component_data_aggregator", "label": "Data Aggregator", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.1", "rationale": "Pure data plumbing layer. Pulls from Circle Wallets, Arc ledger, price oracles, onchain signals. Outputs PortfolioSnapshot. No LLM involved.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "component_llm_goal_parser", "label": "LLM Goal Parser", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.2", "rationale": "Translates natural-language user goals into machine-readable UserPolicy constraints. Single Claude API call on onboarding.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "component_llm_regime_classifier", "label": "LLM Regime Classifier", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.3", "rationale": "Classifies market regime (risk-on/risk-off/neutral) from structured onchain signals. LLM handles ambiguous middle ground better than hard thresholds.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "component_decision_engine", "label": "Decision Engine", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.4", "rationale": "Deterministic code layer. Three modules: Rebalance Optimizer, Loss Harvest Scanner, Holding Period Tracker. Flags candidate actions. Fast, cheap, predictable - no LLM.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "component_llm_action_reasoner", "label": "LLM Action Reasoner", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.5", "rationale": "The judgment layer. Decides whether to EXECUTE, DEFER, or SKIP flagged candidates. Weighs wash sale timing against regime direction against transaction cost - where LLM adds value over rules engine.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "component_execution_layer", "label": "Execution Layer (Circle Stack)", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.6", "rationale": "Executes LLM-approved actions with minimal friction and full audit trail. Uses Circle Wallets, CCTP/Gateway, USYC parking, Paymaster gas abstraction.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "component_arc_ledger", "label": "Arc Ledger", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.6", "rationale": "Immutable disposal record \u2192 Form 8949 pre-fill. Writes every disposal with lot ID, cost basis, proceeds, gain/loss, timestamp, rationale.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "data_model_agent", "label": "Agent Entity", "file_type": "code", "source_file": "architecture.md", "source_location": "section 4.3", "rationale": "Core backend entity. Contains id, userId, status, wallets, policy, approval settings, deployment mode, notification channels, heartbeat interval.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "data_model_user_policy", "label": "UserPolicy", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.2", "rationale": "Machine-readable policy from natural language. Contains primaryObjective, harvestThresholdPct, maturationBufferDays, rebalanceAggressiveness, allowedActions.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "data_model_portfolio_snapshot", "label": "PortfolioSnapshot", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.1", "rationale": "Aggregated view of positions, prices, realized YTD gains/losses, regime signals, and user policy. Consumed by downstream decision layers.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "data_model_lot", "label": "Lot Entity", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.1", "rationale": "Tax lot with id, acquiredAt, costBasisUsd, quantity, sourceTx, status, holdingPeriodDays. The unit of truth for tax calculations.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "data_model_candidate_action", "label": "CandidateAction", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.4", "rationale": "Output of Decision Engine. Contains type (REBALANCE/HARVEST/PARK), priority, lots, estimated tax impact, gas cost, replacement asset, wash sale status.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "deployment_mode_hosted", "label": "Hosted Mode", "file_type": "document", "source_file": "architecture.md", "source_location": "section 5", "rationale": "taxee runs heartbeat on our infrastructure. TG + web notify. Circle executes. Default retail UX.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "deployment_mode_mcp", "label": "MCP Mode", "file_type": "document", "source_file": "architecture.md", "source_location": "section 5", "rationale": "User's OpenClaw/Claude Desktop agent calls taxee MCP tools on demand. User's agent owns notification channel. Power users, custom workflows.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "approval_mode_manual", "label": "Manual Approval Mode", "file_type": "document", "source_file": "architecture.md", "source_location": "section 6.1", "rationale": "Agent proposes \u2192 user must Execute/Defer/Skip before any transaction. Best for first-time users, large tax impact, learning the agent.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "approval_mode_delegated", "label": "Delegated Approval Mode", "file_type": "document", "source_file": "architecture.md", "source_location": "section 6.1", "rationale": "Agent executes autonomously when Decision Engine + LLM Reasoner agree and policy guardrails pass. User receives post-action notify. Set-and-forget.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "strategy_harvest", "label": "Loss Harvest Strategy", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.4", "rationale": "Scans positions for unrealized loss > threshold. Flags HARVEST with correlated replacement asset. Checks wash sale window (30 days).", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "strategy_rebalance", "label": "Rebalance Strategy", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.4", "rationale": "Compares drift_cost vs tax_cost of HIFO disposal. If drift_cost > tax_cost, flags REBALANCE. Otherwise HOLD and re-check in 24h.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "strategy_park", "label": "Maturation Park Strategy", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.4", "rationale": "Tracks days_to_longterm for each lot. If < 30 days AND lot has unrealized gain, flags PARK_IN_USYC - park for yield while aging toward long-term treatment.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "external_circle_wallets", "label": "Circle Programmable Wallets", "file_type": "document", "source_file": "architecture.md", "source_location": "section 7.1", "rationale": "MPC-secured wallet for execute tier. taxee signs via API with spend limits. Never stores user private keys - only circleWalletId and policy limits.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "external_cctp", "label": "Circle CCTP", "file_type": "document", "source_file": "architecture.md", "source_location": "section 8.6", "rationale": "Cross-chain USDC burn/mint bridge for moving value between chains with consistent settlement.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "external_usyc", "label": "USYC (USDC Yield Token)", "file_type": "document", "source_file": "architecture.md", "source_location": "section 8.6", "rationale": "BlackRock USD Institutional Digital Liquidity Fund. Parking destination for maturing lots - earn yield while lot ages toward long-term treatment.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "external_paymaster", "label": "Circle Paymaster", "file_type": "document", "source_file": "architecture.md", "source_location": "section 8.6", "rationale": "ERC-4337 paymaster for gas abstraction - users pay gas in USDC, not ETH.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "external_telegram", "label": "Telegram Bot API", "file_type": "document", "source_file": "architecture.md", "source_location": "section 12", "rationale": "Primary notification channel. Uses grammy/telegraf. Handles onboarding, rich opportunity notifications with inline buttons (Execute/Defer/Skip).", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "user_lifecycle_onboarding", "label": "User Onboarding Phase", "file_type": "document", "source_file": "architecture.md", "source_location": "section 3", "rationale": "Phase 1: Connect wallet \u2192 import history \u2192 set preferences \u2192 done (~2 minutes). Never repeat. Watch tier starts here (address only, no keys).", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "user_lifecycle_heartbeat", "label": "Heartbeat Phase", "file_type": "document", "source_file": "architecture.md", "source_location": "section 3", "rationale": "Phase 2: Hourly scan \u2192 agent reasons \u2192 notify on opportunity. Zero user effort. Runs continuously.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "user_lifecycle_action_loop", "label": "Action Loop Phase", "file_type": "document", "source_file": "architecture.md", "source_location": "section 3", "rationale": "Phase 3: Manual (Execute/Defer/Skip per opportunity) or Delegated (auto-execute within guardrails). User notified always.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "key_custody_watch_tier", "label": "Watch Tier Key Model", "file_type": "document", "source_file": "architecture.md", "source_location": "section 7.1", "rationale": "User keeps all keys. Agent can scan, reason, notify only. Address-only onboarding. TG bot works day one; user executes in own wallet.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "key_custody_execute_tier", "label": "Execute Tier Key Model", "file_type": "document", "source_file": "architecture.md", "source_location": "section 7.1", "rationale": "Circle Programmable Wallets or session key. Agent can execute approved transactions. User creates/funds Circle wallet; taxee signs via API.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "lot_selection_hifo", "label": "HIFO Lot Selection", "file_type": "code", "source_file": "architecture.md", "source_location": "section 8.4", "rationale": "Highest-In, First-Out. Selects lots with highest cost basis first \u2192 minimizes realized gain. IRS-compliant when combined with specific identification at execution.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "wash_sale_rule", "label": "Wash Sale Rule Handling", "file_type": "document", "source_file": "architecture.md", "source_location": "section 8.4", "rationale": "30-day window check since last buy of same asset. If window open, may defer harvest or park in USYC. Replaces with correlated asset (e.g., ETH\u2192stETH, \u03c1=0.94) to maintain exposure.", "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "taxee_system", "target": "design_principle_tax_first_class", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score"